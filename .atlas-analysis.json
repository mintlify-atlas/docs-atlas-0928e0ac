  "keyFeatures": [
    "RAG-based chatbot powered by Groq Llama 3.3 70B",
    "HuggingFace sentence-transformers embeddings (all-MiniLM-L6-v2)",
    "Hybrid vector search with LanceDB",
    "PDF, TXT, and Markdown document ingestion",
    "Persistent conversation sessions via SQLite",
    "CORS-enabled for web frontend integration",
    "On-startup and on-demand document reindexing"
  ],
  "publicApiSurface": [
    "GET /health",
    "POST /chat",
    "POST /reindex",
    "ChatRequest (message, session_id, user_id)",
    "ChatResponse (session_id, answer)",
    "ReindexResponse (status, files_indexed)"
  ]
